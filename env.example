# TP_sleeve — copy to .env (never commit .env)

# cTrader Open API (demo or live)
# CTRADER_CLIENT_ID=
# CTRADER_CLIENT_SECRET=
# CTRADER_ACCOUNT_ID=
# CTRADER_HOST=demo.ctraderapi.com
# CTRADER_PORT=5035
# CTRADER_OAUTH_REDIRECT_URI=http://localhost
# CTRADER_ACCESS_TOKEN=
# CTRADER_REFRESH_TOKEN=

# TP paper ops
# TP_REBALANCE_MODE=offline
# TP_EQUITY=100000
# TP_GROSS_LEVERAGE=0.02
# TP_EXECUTE=0

# Phase 2 paper orders (both required with --execute)
# FXAIEA_TP_ALLOW_CTRADER_ORDERS=I_UNDERSTAND_THIS_CAN_PLACE_BROKER_ORDERS
